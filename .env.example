# Cloud Service Manager API Configuration
# Copy this file to .env and configure your settings

# =============================================================================
# API Server Configuration
# =============================================================================

# Port to expose the API on the host
API_PORT=8000

# Enable API key authentication (true/false)
ENABLE_API_AUTH=false

# API key for authentication (required if ENABLE_API_AUTH=true)
# Generate a strong random key: openssl rand -hex 32
API_KEY=your-secret-api-key-here

# =============================================================================
# AWS Credentials (Optional)
# =============================================================================

# AWS Access Keys (not recommended, use AWS CLI or IAM roles instead)
#AWS_ACCESS_KEY_ID=your-aws-access-key
#AWS_SECRET_ACCESS_KEY=your-aws-secret-key
#AWS_DEFAULT_REGION=us-east-1

# AWS Profile (recommended for local development)
#AWS_PROFILE=default

# AWS Shared Credentials File
#AWS_SHARED_CREDENTIALS_FILE=~/.aws/credentials

# =============================================================================
# Azure Credentials (Optional)
# =============================================================================

# Azure Service Principal
#AZURE_TENANT_ID=your-tenant-id
#AZURE_CLIENT_ID=your-client-id
#AZURE_CLIENT_SECRET=your-client-secret
#AZURE_SUBSCRIPTION_ID=your-subscription-id

# =============================================================================
# Google Cloud Platform Credentials (Optional)
# =============================================================================

# Path to GCP service account key JSON file
#GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# GCP Project ID
#GCP_PROJECT=your-gcp-project-id

# GCP Credentials File (for Application Default Credentials)
#GCP_CREDENTIALS_FILE=~/.config/gcloud/application_default_credentials.json

# =============================================================================
# Development & Debugging
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
#LOG_LEVEL=INFO

# Enable Uvicorn reload on code changes (development only)
#UVICORN_RELOAD=true
